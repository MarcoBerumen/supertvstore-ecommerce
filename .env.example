# =============================================================================
# Supabase (local stack runs on custom ports — see supabase/config.toml)
# =============================================================================
# After `supabase start`, copy the API URL + publishable/anon key it prints.
# The local API URL with our custom port is http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# =============================================================================
# Google OAuth (read by supabase/config.toml via env() substitution)
# =============================================================================
# Get these from Google Cloud Console > APIs & Services > Credentials.
# Create an OAuth 2.0 Client ID (type: Web application). Authorized redirect URI:
#   http://127.0.0.1:64321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# =============================================================================
# MariaDB (existing brick-and-mortar catalog — read-only from this app)
# =============================================================================
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_DATABASE=supertvstore
